# ~/.config/ghostty/config — managed by dev-env-setup (stow ghostty).

font-family = "JetBrainsMono Nerd Font"
font-size = 14

theme = "Tokyo Night"

cursor-style = block
cursor-style-blink = false

window-padding-x = 8
window-padding-y = 8

mouse-hide-while-typing = true
copy-on-select = clipboard

confirm-close-surface = false
